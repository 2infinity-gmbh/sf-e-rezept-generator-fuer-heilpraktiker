---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Artikel über E-Rezepte für Heilpraktiker | E-Rezept Generator';
const description = 'Informative Artikel über E-Rezepte, digitale Verordnungen und die Digitalisierung in der Heilpraktiker-Praxis. Bleiben Sie auf dem neuesten Stand.';

const articles = [
  {
    title: 'E-Rezept für Heilpraktiker: Der umfassende Leitfaden für 2024',
    slug: 'e-rezept-heilpraktiker-leitfaden-2024',
    description: 'Das E-Rezept hält Einzug in die deutsche Gesundheitslandschaft. Dieser Leitfaden bietet einen umfassenden Überblick über das E-Rezept für Heilpraktiker im Jahr 2024.',
    publishDate: '2024-01-15'
  },
  {
    title: 'E-Rezept Generator für Heilpraktiker: Digitale Verordnungen einfach erstellen',
    slug: 'e-rezept-generator-heilpraktiker-digitale-verordnungen',
    description: 'Ein E-Rezept Generator bietet die perfekte Lösung, um digitale Verordnungen rechtssicher und professionell zu erstellen.',
    publishDate: '2024-01-20'
  }
];
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="flex-grow bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Page Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Artikel & Ratgeber
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl">
          Informieren Sie sich über E-Rezepte, digitale Verordnungen und die Digitalisierung in der Heilpraktiker-Praxis.
        </p>
      </div>

      <!-- Ad Space -->
      <div class="mb-8 bg-gray-100 rounded-lg p-4 text-center text-gray-400 min-h-[90px] flex items-center justify-center">
        <!-- Ad Placement: Article Listing Top -->
      </div>

      <!-- Articles Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
        {articles.map((article) => (
          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="p-6">
              <div class="text-sm text-gray-500 mb-2">
                {new Date(article.publishDate).toLocaleDateString('de-DE', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </div>
              <h2 class="text-2xl font-bold text-gray-900 mb-3">
                <a href={`/artikel/${article.slug}`} class="hover:text-primary-600">
                  {article.title}
                </a>
              </h2>
              <p class="text-gray-600 mb-4">
                {article.description}
              </p>
              <a
                href={`/artikel/${article.slug}`}
                class="inline-block text-primary-600 hover:text-primary-700 font-semibold"
              >
                Weiterlesen →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
